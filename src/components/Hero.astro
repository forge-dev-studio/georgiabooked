---
import CountyHeatmap from '@components/CountyHeatmap.astro';
import { url } from '@lib/url';
---
<section class="hero-section max-w-site mx-auto px-4 pt-14 md:pt-20 pb-14 md:pb-20">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-start">
    <div class="lg:col-span-7 stagger-in">
      <div class="flex items-center gap-3 mb-6">
        <span class="inline-block h-px w-10 bg-crimson"></span>
        <span class="eyebrow">Public Records · Georgia</span>
      </div>
      <h1
        class="display-headline text-textPrimary mb-8"
        style="font-size: clamp(2.2rem, 4.5vw, 4rem);"
      >
        Every arrest.<br/>
        Every county.<br/>
        <span class="text-crimson italic" style="font-style: italic; font-variation-settings: 'opsz' 72;">Public record.</span>
      </h1>
      <p class="display-dek text-textSecondary max-w-xl mb-10" style="font-size: clamp(1.15rem, 1.6vw, 1.5rem);">
        Factual, sourced, updated hourly. Every jail booking across Georgia's 159 counties, searchable by name and filterable by charge severity. Presumption of innocence in every report.
      </p>
      <div class="flex flex-wrap items-center gap-3">
        <a href={url('/counties/')} class="btn-primary">
          Browse by county
          <span aria-hidden="true" class="ml-1">→</span>
        </a>
        <a href={url('/charges/')} class="btn-ghost">
          Charge breakdown
        </a>
      </div>
    </div>
    <div class="lg:col-span-5 stagger-in">
      <figure class="hero-map-frame relative">
        <div class="hero-map-caption flex items-baseline justify-between gap-4 py-3 px-4 hairline-bottom">
          <span class="eyebrow-muted">Heatmap · Last 7 Days</span>
          <span class="text-[10px] uppercase tracking-[0.24em] text-textMuted">Tap any county</span>
        </div>
        <div class="hero-map-body">
          <CountyHeatmap compact />
        </div>
        <figcaption class="hero-map-footer flex items-center justify-between py-3 px-4 hairline-top text-[10px] uppercase tracking-[0.24em] text-textMuted">
          <span class="flex items-center gap-2">
            <span>Fewer</span>
            <span class="inline-flex items-center gap-px">
              <span class="inline-block w-3 h-2" style="background: rgba(220, 38, 38, 0.12);"></span>
              <span class="inline-block w-3 h-2" style="background: rgba(220, 38, 38, 0.3);"></span>
              <span class="inline-block w-3 h-2" style="background: rgba(220, 38, 38, 0.55);"></span>
              <span class="inline-block w-3 h-2" style="background: rgba(220, 38, 38, 0.8);"></span>
            </span>
            <span>More</span>
          </span>
          <span>159 counties</span>
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<style>
  .hero-map-frame {
    border: 1px solid rgba(241, 245, 249, 0.1);
    background: rgba(13, 21, 36, 0.55);
    box-shadow: 0 24px 60px -24px rgba(0, 0, 0, 0.55);
  }
  .hero-map-body :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }
  .hero-map-body :global(.heatmap-wrapper > h2),
  .hero-map-body :global(.heatmap-wrapper > p) {
    display: none;
  }
</style>
