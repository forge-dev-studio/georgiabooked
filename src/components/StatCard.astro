---
export interface Props {
  label: string;
  value: string | number;
  context?: string;
  accent?: 'crimson' | 'gold' | 'default';
}

const { label, value, context, accent = 'default' } = Astro.props;
const valueClass = accent === 'crimson'
  ? 'text-crimson'
  : accent === 'gold'
  ? 'text-gold'
  : 'text-textPrimary';
---
<div class="stat-card relative py-6 px-5">
  <div class="text-[10px] uppercase tracking-[0.28em] font-semibold text-textMuted mb-3">
    {label}
  </div>
  <div class:list={['font-serif font-semibold leading-none tabular text-5xl md:text-6xl animate-count-up', valueClass]}
       style="letter-spacing: -0.04em; font-variation-settings: 'opsz' 72;">
    {value}
  </div>
  {context && (
    <div class="mt-3 text-[11px] text-textSecondary tracking-wide">
      {context}
    </div>
  )}
</div>

<style>
  .stat-card {
    border-left: 1px solid rgba(241, 245, 249, 0.1);
  }
  .stat-card:first-child {
    border-left: 0;
  }
  @media (max-width: 767px) {
    .stat-card {
      border-left: 0;
      border-top: 1px solid rgba(241, 245, 249, 0.1);
    }
    .stat-card:first-child {
      border-top: 0;
    }
  }
</style>
