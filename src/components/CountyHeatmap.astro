---
import fs from 'node:fs';
import path from 'node:path';
import { loadArrests, countyHotness } from '@lib/data';
import { counties } from '@lib/counties';

const arrests = loadArrests();
const hotness = countyHotness(arrests, 7);
const maxCount = Math.max(1, ...Array.from(hotness.values()));

const svgPath = path.resolve(process.cwd(), 'public/ga-counties.svg');
const rawSvg = fs.readFileSync(svgPath, 'utf8');

let annotated = rawSvg;
for (const c of counties) {
  const count = hotness.get(c.name) ?? 0;
  const intensity = count / maxCount;
  const alpha = 0.05 + intensity * 0.75;
  const link = `/counties/${c.slug}/`;
  const title = `${c.name} County - ${count} this week`;
  annotated = annotated.replace(
    new RegExp(`<path id="county-${c.slug}"([^/]*?)/>`, 's'),
    `<a href="${link}"><path id="county-${c.slug}"$1 style="fill:rgba(220,38,38,${alpha});cursor:pointer"><title>${title}</title></path></a>`
  );
}
---
<section class="relative">
  <div class="absolute top-0 left-0 right-0 z-10 p-4 flex justify-between items-start pointer-events-none">
    <div>
      <h2 class="font-serif text-2xl font-semibold">Hot counties, last 7 days</h2>
      <p class="text-sm text-textSecondary">Redder = more bookings this week</p>
    </div>
  </div>
  <div set:html={annotated} class="max-w-site mx-auto" />
</section>
