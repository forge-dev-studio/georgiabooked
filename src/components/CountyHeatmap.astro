---
import fs from 'node:fs';
import path from 'node:path';
import { loadArrests, countyHotness } from '@lib/data';
import { counties } from '@lib/counties';
import { url } from '@lib/url';

export interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;

const arrests = loadArrests();
const hotness = countyHotness(arrests, 7);
const maxCount = Math.max(1, ...Array.from(hotness.values()));

// Identify hottest county for pulse animation
let hottestName: string | null = null;
let hottestCount = 0;
for (const [name, count] of hotness.entries()) {
  if (count > hottestCount) {
    hottestCount = count;
    hottestName = name;
  }
}

const svgPath = path.resolve(process.cwd(), 'public/ga-counties.svg');
const rawSvg = fs.readFileSync(svgPath, 'utf8');

let annotated = rawSvg;
for (const c of counties) {
  const count = hotness.get(c.name) ?? 0;
  const intensity = count / maxCount;
  const alpha = count === 0 ? 0.04 : 0.1 + intensity * 0.78;
  const link = url(`/counties/${c.slug}/`);
  const title = `${c.name} County - ${count} this week`;
  const isHottest = c.name === hottestName && count > 0;
  const strokeAttr = 'stroke="rgba(241,245,249,0.22)" stroke-width="0.6"';
  const pulseClass = isHottest ? ' class="heatmap-hottest"' : '';
  annotated = annotated.replace(
    new RegExp(`<path id="county-${c.slug}"([^>]*?)>\\s*<title>[^<]*</title>\\s*</path>`, 's'),
    `<a href="${link}"><path id="county-${c.slug}"$1${pulseClass} ${strokeAttr} style="fill:rgba(220,38,38,${alpha});cursor:pointer;transition:fill 220ms ease, stroke 220ms ease"><title>${title}</title></path></a>`
  );
}
---
<section class:list={['heatmap-wrapper relative', compact && 'is-compact']}>
  {!compact && (
    <div class="flex items-baseline justify-between mb-5">
      <div>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-textPrimary" style="letter-spacing: -0.025em;">Hot counties, last 7 days</h2>
        <p class="text-sm text-textSecondary mt-1.5">Redder = more bookings this week</p>
      </div>
      <span class="text-[10px] uppercase tracking-[0.24em] text-textMuted hidden md:inline">
        Tap any county for details
      </span>
    </div>
  )}
  <div set:html={annotated} class="heatmap-svg-wrap" />
</section>

<style is:global>
  .heatmap-svg-wrap svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .heatmap-svg-wrap path[id^="county-"]:hover {
    fill: #dc2626 !important;
    stroke: rgba(251, 191, 36, 0.8) !important;
    stroke-width: 1 !important;
  }
  @keyframes heatmapPulse {
    0%, 100% {
      filter: drop-shadow(0 0 0 rgba(220, 38, 38, 0));
    }
    50% {
      filter: drop-shadow(0 0 8px rgba(220, 38, 38, 0.75));
    }
  }
  .heatmap-svg-wrap .heatmap-hottest {
    animation: heatmapPulse 2.4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>
