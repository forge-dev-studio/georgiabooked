---
import { counties } from '@lib/counties';
import { url } from '@lib/url';

export interface Props {
  entries: Array<[string, number]>;
  limit?: number;
}

const { entries, limit = 10 } = Astro.props;
const top = entries.slice(0, limit);
const max = Math.max(1, ...top.map(([, n]) => n));
---
<div class="hot-counties">
  <ol class="space-y-0">
    {top.map(([name, count], i) => {
      const c = counties.find((x) => x.name === name);
      if (!c) return null;
      const pct = Math.max(6, Math.round((count / max) * 100));
      const isTop3 = i < 3;
      return (
        <li>
          <a
            href={url(`/counties/${c.slug}/`)}
            class="group flex items-center gap-4 md:gap-6 py-4 md:py-5 hairline-top transition"
          >
            <span
              class:list={[
                'font-serif font-bold tabular w-12 text-center flex-shrink-0 leading-none',
                isTop3 ? 'text-crimson text-4xl md:text-5xl' : 'text-textMuted text-3xl md:text-4xl',
              ]}
              style="letter-spacing: -0.04em; font-variation-settings: 'opsz' 72;"
            >
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="flex-shrink-0 w-36 md:w-44">
              <div class="font-serif text-lg md:text-xl font-semibold text-textPrimary group-hover:text-crimson transition leading-tight" style="letter-spacing: -0.02em;">
                {c.name}
              </div>
              <div class="text-[11px] uppercase tracking-[0.2em] text-textMuted font-medium mt-0.5">
                {c.seat}
              </div>
            </div>
            <div class="flex-1 min-w-0 relative h-2 overflow-hidden" style="background: rgba(241, 245, 249, 0.05);">
              <div
                class="h-full transition-all duration-700"
                style={`width: ${pct}%; background: linear-gradient(90deg, #991b1b 0%, #dc2626 100%);`}
              ></div>
            </div>
            <span class="font-mono tabular text-xl md:text-2xl font-medium text-textPrimary w-14 text-right flex-shrink-0">
              {count}
            </span>
          </a>
        </li>
      );
    })}
  </ol>
</div>
