---
import { url } from '@lib/url';

export interface Props {
  placement: 'header-banner' | 'sidebar-rectangle' | 'inline-native' | 'footer-banner';
  county?: string;
}

const { placement, county } = Astro.props;

const dims: Record<Props['placement'], { w: number; h: number; label: string }> = {
  'header-banner': { w: 728, h: 90, label: '728 x 90' },
  'sidebar-rectangle': { w: 300, h: 250, label: '300 x 250' },
  'inline-native': { w: 0, h: 0, label: 'Native sponsored content' },
  'footer-banner': { w: 728, h: 90, label: '728 x 90' },
};

const { w, h, label } = dims[placement];
---
<div class="ad-slot my-6 max-w-site mx-auto px-4" data-placement={placement} data-county={county}>
  <div class="text-[10px] uppercase tracking-[0.28em] text-textMuted mb-2 text-right font-semibold">Advertisement</div>
  <div
    class="flex items-center justify-center text-textMuted text-[11px] uppercase tracking-[0.24em] font-mono tabular bg-surface/30"
    style={w > 0 ? `max-width:${w}px;min-height:${h}px;margin:0 auto;border: 1px dashed rgba(241, 245, 249, 0.1);` : 'min-height:72px;border-top: 1px dashed rgba(241, 245, 249, 0.1); border-bottom: 1px dashed rgba(241, 245, 249, 0.1);'}
  >
    <span>{label}</span>
    {placement === 'sidebar-rectangle' && (
      <a href={url('/advertise')} class="ml-3 text-gold hover:text-crimson transition normal-case tracking-normal">Advertise here</a>
    )}
  </div>
</div>
