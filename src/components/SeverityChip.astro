---
import { SEVERITY_LABEL, type Severity } from '@lib/severity';

export interface Props {
  severity: Severity;
  size?: 'sm' | 'md';
}

const { severity, size = 'md' } = Astro.props;
const label = SEVERITY_LABEL[severity];

const colorMap: Record<Severity, string> = {
  violent_felony: 'text-red-400',
  felony: 'text-crimson',
  serious_misdemeanor: 'text-amber-400',
  misdemeanor: 'text-emerald-400',
};
const color = colorMap[severity];
const sizeClass = size === 'sm' ? 'text-[10px]' : 'text-[11px]';
---
<span class={`inline-flex items-center gap-1.5 font-semibold uppercase tracking-[0.22em] ${color} ${sizeClass}`}>
  <span class="inline-block w-1.5 h-1.5 rounded-full" style={`background: currentColor;`}></span>
  {label}
</span>
