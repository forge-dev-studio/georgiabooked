---
import { top20Counties } from '@lib/counties';
import { url } from '@lib/url';

const today = new Date().toLocaleDateString('en-US', {
  weekday: 'long', month: 'long', day: 'numeric', year: 'numeric',
});
---
<header class="sticky top-0 z-40 bg-base/92 backdrop-blur-md hairline-bottom">
  <div class="max-w-site mx-auto px-4 flex items-center justify-between gap-6 py-3.5">
    <div class="flex items-center gap-5">
      <a href={url('/')} class="flex items-baseline gap-3">
        <span class="font-serif text-2xl font-bold tracking-tightest leading-none text-textPrimary" style="font-variation-settings: 'opsz' 48;">
          Georgia<span class="text-crimson">Booked</span>
        </span>
      </a>
      <span class="hidden lg:inline-block h-4 w-px bg-textMuted/30"></span>
      <span class="hidden lg:inline-block text-[10px] uppercase tracking-[0.24em] text-textMuted font-medium">
        {today}
      </span>
    </div>
    <nav class="flex items-center gap-6 text-[13px] font-medium">
      <div class="relative group">
        <button class="text-textSecondary hover:text-textPrimary transition flex items-center gap-1">
          Counties
          <svg width="10" height="10" viewBox="0 0 10 10" class="opacity-60"><path d="M2 4l3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
        </button>
        <div class="absolute right-0 top-full pt-2 hidden group-hover:block">
          <div class="grid grid-cols-2 gap-1 bg-surface hairline-top hairline-bottom p-3 min-w-[340px] shadow-2xl" style="border-left: 1px solid rgba(241,245,249,0.12); border-right: 1px solid rgba(241,245,249,0.12);">
            {top20Counties.map((c) => (
              <a href={url(`/counties/${c.slug}/`)} class="text-xs text-textSecondary hover:text-crimson px-2 py-1.5 transition">{c.name}</a>
            ))}
            <a href={url('/counties/')} class="text-[11px] uppercase tracking-[0.2em] font-semibold text-gold px-2 py-2 col-span-2 mt-1" style="border-top: 1px solid rgba(241,245,249,0.1);">All 159 counties</a>
          </div>
        </div>
      </div>
      <a href={url('/charges/')} class="text-textSecondary hover:text-textPrimary transition hidden md:inline">Charges</a>
      <a href={url('/about')} class="text-textSecondary hover:text-textPrimary transition hidden md:inline">About</a>
      <a href={url('/search')} class="text-textSecondary hover:text-textPrimary transition flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span class="hidden md:inline">Search</span>
      </a>
    </nav>
  </div>
</header>
