---
import { loadArrests, arrestsInLast24h } from '@lib/data';

const arrests = loadArrests();
const last24 = arrestsInLast24h(arrests);
const counties = new Set(last24.map((r) => r.county)).size;
const felonies = last24.filter((r) => r.severity === 'felony' || r.severity === 'violent_felony').length;
---
<div class="hairline-y bg-base/60 backdrop-blur">
  <div class="max-w-site mx-auto px-4 py-2.5 flex items-center gap-4 text-xs whitespace-nowrap overflow-x-auto">
    <span class="inline-flex items-center gap-2 flex-shrink-0">
      <span class="relative flex h-1.5 w-1.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-crimson opacity-70"></span>
        <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-crimson"></span>
      </span>
      <span class="text-[10px] uppercase tracking-[0.28em] font-semibold text-crimson">Live</span>
    </span>
    <span class="text-textMuted">/</span>
    <span class="text-textSecondary">
      Last 24h:
      <strong class="font-mono tabular text-textPrimary font-medium">{last24.length}</strong>
      bookings across
      <strong class="font-mono tabular text-textPrimary font-medium">{counties}</strong>
      counties,
      <strong class="font-mono tabular text-crimson font-medium">{felonies}</strong>
      felonies
    </span>
    <span class="text-textMuted hidden sm:inline">/</span>
    <span class="text-textMuted text-[11px] hidden sm:inline">Updated hourly</span>
  </div>
</div>
