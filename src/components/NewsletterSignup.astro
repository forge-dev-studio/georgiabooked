---
// Formspree endpoint swapped in later; for now a stub action placeholder
---
<section class="py-20 md:py-28 relative">
  <div class="max-w-narrow mx-auto px-4">
    <hr class="rule-hair mb-12" />
    <div class="grid grid-cols-1 md:grid-cols-5 gap-10 items-start">
      <div class="md:col-span-3">
        <span class="eyebrow">Morning dispatch</span>
        <h2 class="font-serif text-4xl md:text-5xl font-semibold mt-4 mb-4 text-balance" style="letter-spacing: -0.03em; line-height: 0.98;">
          The Daily <span class="text-crimson italic" style="font-style: italic;">Booking</span>
        </h2>
        <p class="text-textSecondary text-lg leading-relaxed max-w-lg">
          Every morning at 7 AM ET: new Georgia arrests from the last 24 hours, county rankings, notable felonies. Factual. Searchable. Free.
        </p>
      </div>
      <div class="md:col-span-2 md:pt-14">
        <form action="https://formspree.io/f/REPLACE_ME" method="POST" class="flex flex-col gap-3">
          <input
            type="email"
            name="email"
            required
            placeholder="you@email.com"
            class="bg-transparent text-textPrimary px-0 py-3 text-base focus:outline-none placeholder:text-textMuted"
            style="border: 0; border-bottom: 1px solid rgba(241, 245, 249, 0.25); border-radius: 0;"
          />
          <button type="submit" class="btn-primary justify-center">
            Subscribe
          </button>
          <p class="text-[10px] text-textMuted mt-1 uppercase tracking-[0.24em]">No spam. Unsubscribe any time.</p>
        </form>
      </div>
    </div>
  </div>
</section>
