---
import BaseLayout from '@layouts/BaseLayout.astro';
import ArrestCard from '@components/ArrestCard.astro';
import AdSlot from '@components/AdSlot.astro';
import StatCard from '@components/StatCard.astro';
import { counties } from '@lib/counties';
import { loadArrests, arrestsByCounty } from '@lib/data';
import { breadcrumbSchema } from '@lib/schema';
import { url } from '@lib/url';

export async function getStaticPaths() {
  return counties.map((c) => ({ params: { county: c.slug }, props: { county: c } }));
}

const { county } = Astro.props;
const all = loadArrests();
const arrests = arrestsByCounty(all, county.name);
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://forge-dev-studio.github.io';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteBase = `${site}${baseUrl}`;

const last7 = arrests.filter((r) => Date.parse(r.publishedAt) >= Date.now() - 7 * 86400000).length;
const last30 = arrests.filter((r) => Date.parse(r.publishedAt) >= Date.now() - 30 * 86400000).length;

const schema = breadcrumbSchema([
  { name: 'Home', url: siteBase },
  { name: 'Counties', url: `${siteBase}/counties/` },
  { name: `${county.name} County`, url: `${siteBase}/counties/${county.slug}/` },
]);
---
<BaseLayout
  title={`${county.name} County, Georgia Arrests - GeorgiaBooked`}
  description={`Live arrest records for ${county.name} County, Georgia. Seat: ${county.seat}. Population: ${county.population.toLocaleString()}.`}
  jsonLd={schema}
>
  <section class="max-w-site mx-auto px-4 py-14 md:py-20">
    <nav class="text-[11px] text-textMuted uppercase tracking-[0.24em] mb-8 font-medium">
      <a href={url('/')} class="hover:text-crimson transition">Home</a>
      <span class="mx-2 opacity-50">/</span>
      <a href={url('/counties/')} class="hover:text-crimson transition">Counties</a>
      <span class="mx-2 opacity-50">/</span>
      <span class="text-textSecondary">{county.name}</span>
    </nav>

    <header class="mb-12">
      <span class="eyebrow">County file</span>
      <h1 class="font-serif text-5xl md:text-7xl font-semibold mt-4 mb-4 text-balance" style="letter-spacing: -0.035em; line-height: 0.95;">
        {county.name} <span class="italic text-crimson" style="font-style: italic;">County</span>
      </h1>
      <p class="display-dek text-textSecondary text-xl">
        Seat: <span class="text-textPrimary">{county.seat}</span> <span class="opacity-50">·</span> Population: <span class="font-mono tabular text-textPrimary">{county.population.toLocaleString()}</span>
      </p>
    </header>

    <div class="grid grid-cols-3 hairline-top hairline-bottom mb-12">
      <StatCard label="Last 7 days" value={last7} context="new bookings" accent="crimson" />
      <StatCard label="Last 30 days" value={last30} context="tracked arrests" />
      <StatCard label="All-time" value={arrests.length} context="records on file" accent="gold" />
    </div>

    <AdSlot placement="header-banner" county={county.name} />

    {arrests.length === 0 ? (
      <p class="text-textSecondary py-14 text-center hairline-top hairline-bottom font-serif italic text-xl" style="font-style: italic;">
        No arrests tracked yet for {county.name} County. Check back soon.
      </p>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-x-8 stagger-in mt-8">
        {arrests.map((a, i) => (
          <>
            <ArrestCard arrest={a} />
            {(i + 1) % 6 === 0 && <div class="md:col-span-2 lg:col-span-3 py-6"><AdSlot placement="inline-native" county={county.name} /></div>}
          </>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
