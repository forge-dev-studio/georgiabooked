---
import BaseLayout from '@layouts/BaseLayout.astro';
import { counties } from '@lib/counties';
import { loadArrests, countyHotness } from '@lib/data';
import { url } from '@lib/url';

const arrests = loadArrests();
const hotness = countyHotness(arrests, 30);
const totalByCounty = new Map<string, number>();
for (const r of arrests) {
  totalByCounty.set(r.county, (totalByCounty.get(r.county) ?? 0) + 1);
}

const rows = counties.map((c) => ({
  ...c,
  count30d: hotness.get(c.name) ?? 0,
  total: totalByCounty.get(c.name) ?? 0,
})).sort((a, b) => b.count30d - a.count30d || b.population - a.population);
---
<BaseLayout
  title="All 159 Georgia Counties - GeorgiaBooked"
  description="Browse arrest records from every Georgia county. Sorted by recent booking volume."
>
  <section class="max-w-site mx-auto px-4 py-16 md:py-20">
    <div class="mb-12">
      <span class="eyebrow">Directory</span>
      <h1 class="font-serif text-5xl md:text-7xl font-semibold mt-4 mb-4 text-balance" style="letter-spacing: -0.035em; line-height: 0.95;">
        All 159 Georgia <span class="italic text-crimson" style="font-style: italic;">counties</span>
      </h1>
      <p class="display-dek text-textSecondary text-xl max-w-2xl">
        Sorted by bookings in the last 30 days. Click any county for its full arrest history.
      </p>
    </div>
    <div class="hairline-top hairline-bottom overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="text-[10px] uppercase tracking-[0.24em] text-textMuted">
          <tr class="hairline-bottom">
            <th class="px-4 py-3 text-left font-semibold">County</th>
            <th class="px-4 py-3 text-left font-semibold hidden md:table-cell">Seat</th>
            <th class="px-4 py-3 text-right font-semibold">30-day</th>
            <th class="px-4 py-3 text-right font-semibold hidden md:table-cell">All-time</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r, i) => (
            <tr class="group transition" style={i > 0 ? 'border-top: 1px solid rgba(241,245,249,0.06);' : ''}>
              <td class="px-4 py-3">
                <a href={url(`/counties/${r.slug}/`)} class="font-serif text-lg font-semibold text-textPrimary group-hover:text-crimson transition" style="letter-spacing: -0.02em;">
                  {r.name} {r.top20 && <span class="text-gold text-[10px] ml-1 align-middle">*</span>}
                </a>
              </td>
              <td class="px-4 py-3 text-textSecondary hidden md:table-cell text-[13px]">{r.seat}</td>
              <td class="px-4 py-3 text-right font-mono tabular">
                <span class={r.count30d > 0 ? 'text-crimson font-medium' : 'text-textMuted'}>
                  {r.count30d}
                </span>
              </td>
              <td class="px-4 py-3 text-right font-mono tabular text-textSecondary hidden md:table-cell">{r.total}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-[11px] uppercase tracking-[0.2em] text-textMuted mt-5">
      <span class="text-gold">*</span> Top 20 most populous counties by 2020 census
    </p>
  </section>
</BaseLayout>
