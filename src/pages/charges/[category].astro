---
import BaseLayout from '@layouts/BaseLayout.astro';
import ArrestCard from '@components/ArrestCard.astro';
import AdSlot from '@components/AdSlot.astro';
import { SEVERITY_LABEL, type Severity } from '@lib/severity';
import { loadArrests, withPhotos } from '@lib/data';
import { url } from '@lib/url';

export async function getStaticPaths() {
  const slugs = ['violent-felony', 'felony', 'serious-misdemeanor', 'misdemeanor'];
  return slugs.map((slug) => ({ params: { category: slug } }));
}

const SEVERITY_SLUGS: Record<string, Severity> = {
  'violent-felony': 'violent_felony',
  'felony': 'felony',
  'serious-misdemeanor': 'serious_misdemeanor',
  'misdemeanor': 'misdemeanor',
};

const { category } = Astro.params;
const severity = SEVERITY_SLUGS[category!];
if (!severity) throw new Error(`Unknown category: ${category}`);

const arrests = withPhotos(loadArrests().filter((r) => r.severity === severity));
---
<BaseLayout
  title={`${SEVERITY_LABEL[severity]} Arrests in Georgia - GeorgiaBooked`}
  description={`All Georgia arrests classified as ${SEVERITY_LABEL[severity].toLowerCase()}.`}
>
  <section class="max-w-site mx-auto px-4 py-14 md:py-20">
    <nav class="text-[11px] text-textMuted uppercase tracking-[0.24em] mb-8 font-medium">
      <a href={url('/')} class="hover:text-crimson transition">Home</a>
      <span class="mx-2 opacity-50">/</span>
      <a href={url('/charges/')} class="hover:text-crimson transition">Charges</a>
      <span class="mx-2 opacity-50">/</span>
      <span class="text-textSecondary">{SEVERITY_LABEL[severity]}</span>
    </nav>
    <header class="mb-12">
      <span class="eyebrow">Charge dossier</span>
      <h1 class="font-serif text-5xl md:text-7xl font-semibold mt-4 mb-4 text-balance" style="letter-spacing: -0.035em; line-height: 0.95;">
        {SEVERITY_LABEL[severity]} <span class="italic text-crimson" style="font-style: italic;">arrests</span>
      </h1>
      <p class="display-dek text-textSecondary text-xl">
        <span class="font-mono tabular text-textPrimary">{arrests.length}</span> records tracked.
      </p>
    </header>
    <AdSlot placement="header-banner" />
    {arrests.length === 0 ? (
      <p class="text-textSecondary py-14 text-center hairline-top hairline-bottom font-serif italic text-xl" style="font-style: italic;">
        No arrests tracked yet in this category.
      </p>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-2 gap-x-8 stagger-in mt-6">
        {arrests.map((a) => <ArrestCard arrest={a} />)}
      </div>
    )}
  </section>
</BaseLayout>
