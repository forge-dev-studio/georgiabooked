---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SEVERITY_LABEL, type Severity } from '@lib/severity';
import { loadArrests } from '@lib/data';
import { url } from '@lib/url';

const arrests = loadArrests();
const countByCategory: Record<Severity, number> = {
  violent_felony: 0,
  felony: 0,
  serious_misdemeanor: 0,
  misdemeanor: 0,
};
for (const r of arrests) countByCategory[r.severity]++;

const descriptions: Record<Severity, string> = {
  violent_felony: 'Murder, aggravated assault, kidnapping, armed robbery, family-violence battery.',
  felony: 'Drug trafficking, burglary, identity theft, weapons charges, major fraud.',
  serious_misdemeanor: 'DUI, reckless driving, simple battery, obstruction, shoplifting.',
  misdemeanor: 'Traffic violations, failure to appear, minor infractions.',
};
---
<BaseLayout
  title="Browse by Charge Category - GeorgiaBooked"
  description="Georgia arrests grouped by charge severity: violent felonies, felonies, serious misdemeanors, and misdemeanors."
>
  <section class="max-w-site mx-auto px-4 py-14 md:py-20">
    <div class="mb-12">
      <span class="eyebrow">Severity ledger</span>
      <h1 class="font-serif text-5xl md:text-7xl font-semibold mt-4 mb-4 text-balance" style="letter-spacing: -0.035em; line-height: 0.95;">
        Browse by <span class="italic text-crimson" style="font-style: italic;">charge</span>
      </h1>
      <p class="display-dek text-textSecondary text-xl max-w-2xl">
        Classified per Georgia statutory definitions. Each category links to its full dossier of arrests.
      </p>
    </div>
    <div class="grid md:grid-cols-2 gap-0 hairline-top hairline-bottom stagger-in">
      {(['violent_felony', 'felony', 'serious_misdemeanor', 'misdemeanor'] as const).map((sev, i) => (
        <a
          href={url(`/charges/${sev.replace('_', '-')}/`)}
          class="group relative block py-10 px-6 transition"
          style={`${i % 2 === 1 ? 'border-left: 1px solid rgba(241,245,249,0.08);' : ''} ${i >= 2 ? 'border-top: 1px solid rgba(241,245,249,0.08);' : ''}`}
        >
          <div class="kicker mb-4">Tier {i + 1}</div>
          <h2 class="font-serif text-3xl md:text-4xl font-semibold mb-3 text-textPrimary group-hover:text-crimson transition" style="letter-spacing: -0.025em;">
            {SEVERITY_LABEL[sev]}
          </h2>
          <p class="text-textSecondary leading-relaxed mb-6 max-w-md">
            {descriptions[sev]}
          </p>
          <div class="flex items-baseline justify-between">
            <span class="font-serif text-4xl md:text-5xl font-semibold text-crimson tabular" style="letter-spacing: -0.03em;">
              {countByCategory[sev]}
            </span>
            <span class="text-[10px] uppercase tracking-[0.24em] text-textMuted font-semibold group-hover:text-crimson transition inline-flex items-center gap-1 group-hover:gap-2">
              View →
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
