---
import BaseLayout from '@layouts/BaseLayout.astro';
import { loadArrests } from '@lib/data';

const arrests = loadArrests();
const searchIndex = arrests.map((r) => ({
  slug: r.slug,
  name: r.name,
  county: r.county,
  bookingDate: r.bookingDate,
  charges: r.charges,
  severity: r.severity,
}));
const indexJson = JSON.stringify(searchIndex);
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout
  title="Search Georgia Arrests - GeorgiaBooked"
  description="Search every tracked arrest in Georgia by name or charge."
>
  <section class="max-w-narrow mx-auto px-4 py-14 md:py-20">
    <div class="mb-10">
      <span class="eyebrow">Search</span>
      <h1 class="font-serif text-5xl md:text-7xl font-semibold mt-4 mb-4 text-balance" style="letter-spacing: -0.035em; line-height: 0.95;">
        Find an <span class="italic text-crimson" style="font-style: italic;">arrest</span>
      </h1>
      <p class="display-dek text-textSecondary text-lg">
        Searching across <span class="font-mono tabular text-textPrimary">{arrests.length.toLocaleString()}</span> Georgia arrest records.
      </p>
    </div>
    <input
      id="q"
      type="search"
      placeholder="Search by name..."
      autofocus
      class="w-full bg-transparent text-xl md:text-2xl py-4 focus:outline-none placeholder:text-textMuted font-serif"
      style="border: 0; border-bottom: 1px solid rgba(241, 245, 249, 0.22); border-radius: 0; letter-spacing: -0.015em;"
    />
    <div id="search-config" data-base={baseUrl}></div>
    <div id="results" class="mt-8 space-y-0 hairline-top"></div>
  </section>

  <script type="application/json" id="search-index" set:html={indexJson}></script>
  <script>
    import Fuse from 'fuse.js';
    type Item = { slug: string; name: string; county: string; bookingDate: string; charges: string[]; severity: string };
    const indexEl = document.getElementById('search-index');
    const items: Item[] = JSON.parse(indexEl?.textContent ?? '[]');
    const configEl = document.getElementById('search-config') as HTMLElement | null;
    const baseUrl = configEl?.dataset.base ?? '';
    const fuse = new Fuse(items, { keys: ['name', 'county', 'charges'], threshold: 0.35, minMatchCharLength: 2 });
    const q = document.getElementById('q') as HTMLInputElement;
    const results = document.getElementById('results') as HTMLDivElement;
    const urlParams = new URLSearchParams(location.search);
    const initial = urlParams.get('q');
    if (initial) { q.value = initial; render(initial); }
    q.addEventListener('input', () => render(q.value));
    function render(query: string) {
      if (query.trim().length < 2) {
        results.innerHTML = '<p class="text-textMuted text-sm uppercase tracking-widest py-6">Type at least 2 characters.</p>';
        return;
      }
      const hits = fuse.search(query, { limit: 30 });
      if (hits.length === 0) {
        results.innerHTML = '<p class="text-textMuted text-sm uppercase tracking-widest py-6">No results.</p>';
        return;
      }
      results.innerHTML = hits.map(({ item }) => `
        <a href="${baseUrl}/arrests/${item.slug}/" class="group flex items-center justify-between gap-4 py-5 hairline-bottom hover:bg-surface/40 transition px-2">
          <div class="min-w-0">
            <div class="font-serif text-xl md:text-2xl font-semibold text-textPrimary group-hover:text-crimson transition truncate" style="letter-spacing: -0.02em;">${escapeHtml(item.name)}</div>
            <div class="text-[11px] uppercase tracking-[0.22em] text-textMuted mt-1 font-medium">${escapeHtml(item.county)} County &nbsp;/&nbsp; <span class="font-mono tabular">${escapeHtml(item.bookingDate)}</span></div>
          </div>
          <span class="font-mono tabular text-xs text-textSecondary flex-shrink-0">${item.charges.length} charge${item.charges.length === 1 ? '' : 's'}</span>
        </a>
      `).join('');
    }
    function escapeHtml(s: string): string {
      return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] ?? c));
    }
  </script>
</BaseLayout>
