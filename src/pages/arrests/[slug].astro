---
import BaseLayout from '@layouts/BaseLayout.astro';
import SeverityChip from '@components/SeverityChip.astro';
import AdSlot from '@components/AdSlot.astro';
import ArrestCard from '@components/ArrestCard.astro';
import { loadArrests, arrestsByCounty } from '@lib/data';
import { newsArticleSchema, breadcrumbSchema } from '@lib/schema';
import { SEVERITY_LABEL } from '@lib/severity';
import { slugifyCounty } from '@lib/counties';
import { url } from '@lib/url';

export async function getStaticPaths() {
  const arrests = loadArrests();
  return arrests.map((a) => ({ params: { slug: a.slug }, props: { arrest: a } }));
}

const { arrest } = Astro.props;
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://forge-dev-studio.github.io';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteBase = `${site}${baseUrl}`;
const canonical = `${siteBase}/arrests/${arrest.slug}/`;
const countySlug = slugifyCounty(arrest.county);
const allArrests = loadArrests();
const related = arrestsByCounty(allArrests, arrest.county)
  .filter((r) => r.slug !== arrest.slug)
  .slice(0, 6);

const dateDisplay = new Date(arrest.bookingDate + 'T00:00:00').toLocaleDateString('en-US', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
});
const paragraphs = arrest.rewrite.split(/\n\n+/);

const schema = [
  newsArticleSchema(arrest, siteBase),
  breadcrumbSchema([
    { name: 'Home', url: siteBase },
    { name: `${arrest.county} County`, url: `${siteBase}/counties/${countySlug}/` },
    { name: arrest.name, url: canonical },
  ]),
];
---
<BaseLayout
  title={`${arrest.name} booked in ${arrest.county} County, Georgia - ${arrest.bookingDate}`}
  description={`${arrest.name} was booked in ${arrest.county} County, Georgia on ${arrest.bookingDate} and charged with ${arrest.charges.slice(0, 3).join(', ')}.`}
  canonical={canonical}
  ogImage={`${siteBase}/og/${arrest.slug}.png`}
  jsonLd={schema}
>
  <article class="max-w-narrow mx-auto px-4 py-14 md:py-20">
    <nav class="text-[11px] text-textMuted uppercase tracking-[0.24em] mb-10 font-medium">
      <a href={url('/')} class="hover:text-crimson transition">Home</a>
      <span class="mx-2 opacity-50">/</span>
      <a href={url(`/counties/${countySlug}/`)} class="hover:text-crimson transition">{arrest.county} County</a>
      <span class="mx-2 opacity-50">/</span>
      <span class="text-textSecondary">{arrest.name}</span>
    </nav>

    <header class="mb-10">
      <div class="flex items-center gap-3 mb-5">
        <a href={url(`/counties/${countySlug}/`)} class="kicker hover:text-crimson transition">
          {arrest.county} County
        </a>
        <span class="text-textMuted opacity-50">·</span>
        <SeverityChip severity={arrest.severity} />
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-semibold mb-5 text-balance" style="letter-spacing: -0.035em; line-height: 0.95; font-variation-settings: 'opsz' 72;">
        {arrest.name}
      </h1>
      <p class="display-dek text-textSecondary text-xl">Booked {dateDisplay}</p>
    </header>

    <hr class="rule-hair mb-10" />

    <div class="bg-amber-900/10 px-5 py-4 mb-10 text-sm text-amber-100" style="border-left: 2px solid #f59e0b;">
      <strong class="font-semibold">Presumption of innocence.</strong> This is a public-record booking report. {arrest.name} has been charged but not convicted. All charges are allegations and the accused is presumed innocent until proven guilty in a court of law.
    </div>

    {arrest.mugshotUrl && (
      <figure class="mb-10">
        <img
          src={arrest.mugshotUrl}
          alt={`Booking photo of ${arrest.name}`}
          class="w-full max-w-xl grayscale"
          style="border: 1px solid rgba(241, 245, 249, 0.12);"
        />
        <figcaption class="text-[11px] text-textMuted mt-3 uppercase tracking-[0.22em]">
          Booking photo via <a href={arrest.sourceUrl} class="text-gold hover:text-crimson transition" rel="nofollow">Georgia Gazette</a>
        </figcaption>
      </figure>
    )}

    <div class="text-textPrimary leading-relaxed text-lg md:text-xl space-y-5 mb-10 text-pretty" style="font-family: 'Newsreader', Georgia, serif; font-variation-settings: 'opsz' 18;">
      {paragraphs.map((p, i) => (
        <p class={i === 0 ? 'drop-cap' : ''}>{p}</p>
      ))}
    </div>

    <section class="my-12">
      <div class="eyebrow mb-4">Charges filed</div>
      <ul class="hairline-top">
        {arrest.charges.map((charge) => (
          <li class="flex items-start justify-between gap-6 py-4 hairline-bottom">
            <span class="text-textPrimary font-serif text-lg md:text-xl leading-snug" style="letter-spacing: -0.015em;">{charge}</span>
            <span class="text-[10px] uppercase tracking-[0.22em] text-crimson font-semibold flex-shrink-0 mt-1.5">
              {SEVERITY_LABEL[arrest.severity]}
            </span>
          </li>
        ))}
      </ul>
    </section>

    <AdSlot placement="sidebar-rectangle" county={arrest.county} />

    <section class="hairline-top pt-8 mt-12 text-sm text-textSecondary space-y-3">
      <p>
        <strong class="text-textPrimary">Source:</strong>{' '}
        <a href={arrest.sourceUrl} class="text-gold hover:text-crimson transition" rel="nofollow">Georgia Gazette booking report</a>.
        This page consists of public records republished with editorial context.
      </p>
      <p>
        If you believe this record is inaccurate or your charges have been dismissed or expunged,
        <a href={url('/takedown')} class="text-gold hover:text-crimson transition"> request a correction or takedown</a>.
      </p>
    </section>
  </article>

  {related.length > 0 && (
    <section class="max-w-site mx-auto px-4 py-14 md:py-20 hairline-top mt-10">
      <div class="mb-10">
        <span class="eyebrow">Nearby the desk</span>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold mt-3 text-balance" style="letter-spacing: -0.025em;">
          More from {arrest.county} County
        </h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-2 gap-x-8 stagger-in">
        {related.map((r) => <ArrestCard arrest={r} />)}
      </div>
    </section>
  )}

  <AdSlot placement="footer-banner" />
</BaseLayout>
