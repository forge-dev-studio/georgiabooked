---
import BaseLayout from '@layouts/BaseLayout.astro';
import SeverityChip from '@components/SeverityChip.astro';
import AdSlot from '@components/AdSlot.astro';
import ArrestCard from '@components/ArrestCard.astro';
import { loadArrests, arrestsByCounty } from '@lib/data';
import { newsArticleSchema, breadcrumbSchema } from '@lib/schema';
import { SEVERITY_LABEL } from '@lib/severity';
import { slugifyCounty } from '@lib/counties';

export async function getStaticPaths() {
  const arrests = loadArrests();
  return arrests.map((a) => ({ params: { slug: a.slug }, props: { arrest: a } }));
}

const { arrest } = Astro.props;
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://georgiabooked.com';
const canonical = `${site}/arrests/${arrest.slug}/`;
const countySlug = slugifyCounty(arrest.county);
const allArrests = loadArrests();
const related = arrestsByCounty(allArrests, arrest.county)
  .filter((r) => r.slug !== arrest.slug)
  .slice(0, 6);

const dateDisplay = new Date(arrest.bookingDate + 'T00:00:00').toLocaleDateString('en-US', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
});
const paragraphs = arrest.rewrite.split(/\n\n+/);

const schema = [
  newsArticleSchema(arrest, site),
  breadcrumbSchema([
    { name: 'Home', url: site },
    { name: `${arrest.county} County`, url: `${site}/counties/${countySlug}/` },
    { name: arrest.name, url: canonical },
  ]),
];
---
<BaseLayout
  title={`${arrest.name} booked in ${arrest.county} County, Georgia - ${arrest.bookingDate}`}
  description={`${arrest.name} was booked in ${arrest.county} County, Georgia on ${arrest.bookingDate} and charged with ${arrest.charges.slice(0, 3).join(', ')}.`}
  canonical={canonical}
  ogImage={`${site}/og/${arrest.slug}.png`}
  jsonLd={schema}
>
  <article class="max-w-3xl mx-auto px-4 py-10">
    <nav class="text-xs text-textMuted uppercase tracking-widest mb-6">
      <a href="/" class="hover:text-crimson">Home</a>
      <span class="mx-2">/</span>
      <a href={`/counties/${countySlug}/`} class="hover:text-crimson">{arrest.county} County</a>
      <span class="mx-2">/</span>
      <span class="text-textSecondary">{arrest.name}</span>
    </nav>

    <header class="mb-8">
      <div class="flex items-center gap-2 mb-3">
        <a href={`/counties/${countySlug}/`} class="text-xs uppercase tracking-widest text-gold font-semibold hover:underline">
          {arrest.county} County
        </a>
        <span class="text-textMuted">·</span>
        <SeverityChip severity={arrest.severity} />
      </div>
      <h1 class="font-serif text-4xl md:text-5xl font-bold leading-tight mb-3">{arrest.name}</h1>
      <p class="text-lg text-textSecondary">Booked {dateDisplay}</p>
    </header>

    <div class="bg-amber-900/20 border-l-2 border-amber-500 px-4 py-3 mb-6 text-sm text-amber-100">
      <strong>Presumption of innocence:</strong> This is a public-record booking report. {arrest.name} has been charged but not convicted. All charges are allegations and the accused is presumed innocent until proven guilty in a court of law.
    </div>

    {arrest.mugshotUrl && (
      <figure class="mb-6">
        <img
          src={arrest.mugshotUrl}
          alt={`Booking photo of ${arrest.name}`}
          class="w-full max-w-sm border border-border"
        />
        <figcaption class="text-xs text-textMuted mt-2">
          Booking photo provided by source: <a href={arrest.sourceUrl} class="text-gold hover:underline" rel="nofollow">Georgia Gazette</a>
        </figcaption>
      </figure>
    )}

    <div class="prose-arrest text-textPrimary leading-relaxed text-lg mb-8">
      {paragraphs.map((p) => <p class="mb-4">{p}</p>)}
    </div>

    <section class="bg-surface border border-border p-5 mb-6">
      <h2 class="font-serif text-xl font-semibold mb-4">Charges</h2>
      <ul class="space-y-2">
        {arrest.charges.map((charge) => (
          <li class="flex items-center justify-between border-b border-border pb-2 last:border-0">
            <span class="text-textPrimary">{charge}</span>
            <span class="text-xs uppercase tracking-widest text-textMuted">
              {SEVERITY_LABEL[arrest.severity]}
            </span>
          </li>
        ))}
      </ul>
    </section>

    <AdSlot placement="sidebar-rectangle" county={arrest.county} />

    <section class="border-t border-border pt-6 text-sm text-textSecondary">
      <p>
        <strong class="text-textPrimary">Source:</strong>{' '}
        <a href={arrest.sourceUrl} class="text-gold hover:underline" rel="nofollow">Georgia Gazette booking report</a>.
        This page consists of public records republished with editorial context.
      </p>
      <p class="mt-2">
        If you believe this record is inaccurate or your charges have been dismissed/expunged,
        <a href="/takedown" class="text-gold hover:underline">request a correction or takedown</a>.
      </p>
    </section>
  </article>

  {related.length > 0 && (
    <section class="max-w-site mx-auto px-4 py-10 border-t border-border mt-10">
      <h2 class="font-serif text-2xl font-semibold mb-5">More arrests in {arrest.county} County</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {related.map((r) => <ArrestCard arrest={r} />)}
      </div>
    </section>
  )}

  <AdSlot placement="footer-banner" />
</BaseLayout>
