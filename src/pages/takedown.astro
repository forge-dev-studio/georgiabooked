---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout
  title="Takedown / Correction Request - GeorgiaBooked"
  description="Request a correction or takedown of an inaccurate or expunged arrest record."
  noindex={true}
>
  <article class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="font-serif text-4xl font-bold mb-3">Takedown or Correction Request</h1>
    <p class="text-textSecondary mb-6">
      We review every request within 72 hours. Requests supported by documentation (court order, expungement record, news correction) are prioritized.
    </p>

    <form action="https://formspree.io/f/REPLACE_ME_TAKEDOWN" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium mb-1">Your name</label>
        <input type="text" name="requester_name" required class="w-full bg-surface border border-border px-3 py-2 focus:border-crimson focus:outline-none" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Your email</label>
        <input type="email" name="requester_email" required class="w-full bg-surface border border-border px-3 py-2 focus:border-crimson focus:outline-none" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">URL of page to correct/remove</label>
        <input type="url" name="record_url" required placeholder="https://georgiabooked.com/arrests/..." class="w-full bg-surface border border-border px-3 py-2 focus:border-crimson focus:outline-none" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Reason</label>
        <select name="reason" required class="w-full bg-surface border border-border px-3 py-2 focus:border-crimson focus:outline-none">
          <option value="">Select...</option>
          <option value="factual_error">Factual error</option>
          <option value="expunged">Charges expunged or sealed</option>
          <option value="dismissed">Charges dismissed, not guilty, or nolle prossed</option>
          <option value="misidentification">Misidentification</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Details</label>
        <textarea name="details" required rows="6" class="w-full bg-surface border border-border px-3 py-2 focus:border-crimson focus:outline-none"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Link to supporting documentation (optional but preferred)</label>
        <input type="url" name="documentation_url" class="w-full bg-surface border border-border px-3 py-2 focus:border-crimson focus:outline-none" />
      </div>
      <button type="submit" class="btn-primary">Submit request</button>
    </form>

    <p class="text-xs text-textMuted mt-6 leading-relaxed">
      By submitting, you affirm the information provided is accurate. False takedown requests may be rejected or reported to law enforcement if fraudulent.
    </p>
  </article>
</BaseLayout>
