---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout
  title="Takedown / Correction Request - GeorgiaBooked"
  description="Request a correction or takedown of an inaccurate or expunged arrest record."
  noindex={true}
>
  <article class="max-w-narrow mx-auto px-4 py-14 md:py-20">
    <div class="mb-10">
      <span class="eyebrow">Corrections desk</span>
      <h1 class="font-serif text-5xl md:text-7xl font-semibold mt-4 mb-4 text-balance" style="letter-spacing: -0.035em; line-height: 0.95;">
        Takedown or <span class="italic text-crimson" style="font-style: italic;">correction</span>
      </h1>
      <p class="display-dek text-textSecondary text-lg max-w-xl">
        We review every request within 72 hours. Requests supported by documentation (court order, expungement record, news correction) are prioritized.
      </p>
    </div>

    <hr class="rule-hair mb-10" />

    <form action="https://formspree.io/f/REPLACE_ME_TAKEDOWN" method="POST" class="space-y-6">
      <div>
        <label class="block text-[11px] uppercase tracking-[0.22em] text-textMuted font-semibold mb-2">Your name</label>
        <input type="text" name="requester_name" required class="w-full bg-transparent px-0 py-2 text-base focus:outline-none" style="border: 0; border-bottom: 1px solid rgba(241, 245, 249, 0.25); border-radius: 0;" />
      </div>
      <div>
        <label class="block text-[11px] uppercase tracking-[0.22em] text-textMuted font-semibold mb-2">Your email</label>
        <input type="email" name="requester_email" required class="w-full bg-transparent px-0 py-2 text-base focus:outline-none" style="border: 0; border-bottom: 1px solid rgba(241, 245, 249, 0.25); border-radius: 0;" />
      </div>
      <div>
        <label class="block text-[11px] uppercase tracking-[0.22em] text-textMuted font-semibold mb-2">URL of page to correct or remove</label>
        <input type="url" name="record_url" required placeholder="https://georgiabooked.com/arrests/..." class="w-full bg-transparent px-0 py-2 text-base focus:outline-none placeholder:text-textMuted font-mono" style="border: 0; border-bottom: 1px solid rgba(241, 245, 249, 0.25); border-radius: 0;" />
      </div>
      <div>
        <label class="block text-[11px] uppercase tracking-[0.22em] text-textMuted font-semibold mb-2">Reason</label>
        <select name="reason" required class="w-full bg-transparent px-0 py-2 text-base focus:outline-none" style="border: 0; border-bottom: 1px solid rgba(241, 245, 249, 0.25); border-radius: 0;">
          <option value="" style="background:#0d1524;">Select...</option>
          <option value="factual_error" style="background:#0d1524;">Factual error</option>
          <option value="expunged" style="background:#0d1524;">Charges expunged or sealed</option>
          <option value="dismissed" style="background:#0d1524;">Charges dismissed, not guilty, or nolle prossed</option>
          <option value="misidentification" style="background:#0d1524;">Misidentification</option>
          <option value="other" style="background:#0d1524;">Other</option>
        </select>
      </div>
      <div>
        <label class="block text-[11px] uppercase tracking-[0.22em] text-textMuted font-semibold mb-2">Details</label>
        <textarea name="details" required rows="6" class="w-full bg-surface/40 px-4 py-3 text-base focus:outline-none focus:border-crimson" style="border: 1px solid rgba(241, 245, 249, 0.12); border-radius: 0;"></textarea>
      </div>
      <div>
        <label class="block text-[11px] uppercase tracking-[0.22em] text-textMuted font-semibold mb-2">Supporting documentation URL (optional but preferred)</label>
        <input type="url" name="documentation_url" class="w-full bg-transparent px-0 py-2 text-base focus:outline-none font-mono" style="border: 0; border-bottom: 1px solid rgba(241, 245, 249, 0.25); border-radius: 0;" />
      </div>
      <div class="pt-4">
        <button type="submit" class="btn-primary">Submit request</button>
      </div>
    </form>

    <p class="text-[11px] uppercase tracking-[0.22em] text-textMuted mt-10 leading-relaxed">
      By submitting, you affirm the information provided is accurate. False takedown requests may be rejected or reported to law enforcement if fraudulent.
    </p>
  </article>
</BaseLayout>
